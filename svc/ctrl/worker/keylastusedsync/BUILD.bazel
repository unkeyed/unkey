    #   bazel test //svc/ctrl/worker/keylastusedsync:keylastusedsync_test
    tags = ["manual"],
    deps = [
        "//gen/proto/hydra/v1:hydra",
        "//pkg/db",
        "//pkg/hash",
        "//pkg/uid",
        "//svc/ctrl/integration/harness",
        "//svc/ctrl/integration/seed",
        "@com_github_stretchr_testify//require",
