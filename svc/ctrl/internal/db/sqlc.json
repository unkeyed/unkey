{
  "version": "2",
  "sql": [
    {
      "engine": "mysql",
      "queries": "./queries",
      "schema": "../../../../pkg/mysql/schema",
      "codegen": [
        {
          "out": ".",
          "plugin": "bulk-insert",
          "options": {
            "emit_methods_with_db_argument": false
          }
        }
      ],
      "gen": {
        "go": {
          "package": "db",
          "out": ".",
          "sql_package": "database/sql",
          "query_parameter_limit": 1,
          "emit_db_tags": true,
          "emit_interface": true,
          "emit_sql_as_comment": true,
          "emit_methods_with_db_argument": false,
          "output_files_suffix": "_generated",
          "output_models_file_name": "models_generated",
          "output_querier_file_name": "querier_generated",
          "output_batch_file_name": "batch_generated",
          "output_copyfrom_file_name": "copyfrom_generated",
          "output_db_file_name": "delete_me",
          "rename": {
            "quotum": "Quotas"
          },
          "overrides": [
            {
              "db_type": "json",
              "go_type": {
                "type": "[]byte"
              },
              "nullable": true
            },
            {
              "column": "permissions.description",
              "go_type": {
                "type": "NullString",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              },
              "nullable": true
            },
            {
              "column": "deployments.command",
              "go_type": {
                "type": "StringSlice",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              }
            },
            {
              "column": "environment_runtime_settings.command",
              "go_type": {
                "type": "StringSlice",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              }
            },
            {
              "column": "environment_runtime_settings.healthcheck",
              "go_type": {
                "type": "NullHealthcheck",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              },
              "nullable": true
            },
            {
              "column": "deployments.healthcheck",
              "go_type": {
                "type": "NullHealthcheck",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              },
              "nullable": true
            },
            {
              "column": "app_runtime_settings.command",
              "go_type": {
                "type": "StringSlice",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              }
            },
            {
              "column": "app_runtime_settings.healthcheck",
              "go_type": {
                "type": "NullHealthcheck",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              },
              "nullable": true
            },
            {
              "column": "app_build_settings.watch_paths",
              "go_type": {
                "type": "StringSlice",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              }
            },
            {
              "column": "instances.container_status",
              "go_type": {
                "type": "ContainerStatus",
                "package": "dbtype",
                "import": "github.com/unkeyed/unkey/pkg/mysql/types"
              }
            }
          ]
        }
      }
    }
  ],
  "plugins": [
    {
      "name": "bulk-insert",
      "process": {
        "cmd": "../../../../pkg/mysql/plugins/dist/bulk-insert"
      }
    }
  ]
}
