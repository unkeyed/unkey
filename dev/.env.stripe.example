# Stripe test-mode key for the local Deploy billing push (optional).
# Copy this to .env.stripe to exercise the hourly billing push against Stripe
# test mode. Without this file the push runs as a no-op: it still reads and
# aggregates usage and logs the month-to-date numbers, but sends nothing.
#
# Use a TEST-MODE key (sk_test_...). Never put a live key here.
STRIPE_SECRET_KEY=sk_test_...
