# Stripe test-mode credentials for local Deploy billing (optional).
# Copy this to .env.stripe to exercise billing against Stripe test mode. Without
# this file the push runs as a no-op (it logs the numbers it would send) and the
# /webhooks/stripe close handler stays unregistered.
#
# Use a TEST-MODE key (sk_test_...). Never put a live key here.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret for /webhooks/stripe (the month-end invoice close).
# Get it from the Stripe CLI when forwarding events to the local ctrl-api:
#   stripe listen --forward-to https://ctrl-api.unkey.local/webhooks/stripe
# It prints a whsec_... secret; paste it here. Empty leaves the webhook off.
STRIPE_WEBHOOK_SECRET=whsec_...

# Deploy price lookup_keys, used by CancelDeploy to find which subscription
# items to remove. Use the same handles as the dashboard's STRIPE_LOOKUP_DEPLOY_*
# (whatever lookup_key your test account's prices carry). Empty disables
# CancelDeploy (it fails closed rather than guess which items to touch).
STRIPE_DEPLOY_STARTER_LOOKUP_KEY=
STRIPE_DEPLOY_PRO_LOOKUP_KEY=
STRIPE_DEPLOY_BUSINESS_LOOKUP_KEY=
STRIPE_DEPLOY_METER_CPU_LOOKUP_KEY=
STRIPE_DEPLOY_METER_MEMORY_LOOKUP_KEY=
STRIPE_DEPLOY_METER_EGRESS_LOOKUP_KEY=
STRIPE_DEPLOY_METER_DISK_LOOKUP_KEY=
STRIPE_DEPLOY_METER_ACTIVE_KEYS_LOOKUP_KEY=
