load('ext://namespace', 'namespace_create')
load('ext://restart_process',  'docker_build_with_restart')
load('ext://secret', 'secret_create_generic')
load('ext://helm_remote', 'helm_remote')

config.define_string('topolvm_backing_size')
cfg = config.parse()
# Sparse loopback file size. Sparse means this is a ceiling, not a reservation —
# 20 GiB on a fresh cluster costs ~0 bytes. Bump if your test workloads fill more.
TOPOLVM_BACKING_SIZE = cfg.get('topolvm_backing_size', '20G')

update_settings(suppress_unused_image_warnings=["unkey/sentinel:latest"])

# Check which optional credential files exist
has_depot_credentials = os.path.exists('./.env.depot')
has_github_credentials = os.path.exists('./.env.github') and os.path.exists('./.github-private-key.pem')
has_domain_connect_key = os.path.exists('./.domain-connect-private-key.pem')

