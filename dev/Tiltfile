  'namespace',
  'kubectl apply -f k8s/manifests/namespace.yaml',
  labels=['setup'],
)

local_resource(
  'sentinel',
  'kubectl apply -f k8s/manifests/sentinel.yaml',
  labels=['setup'],
)

local_resource(
  'rbac',
  'kubectl apply -f k8s/manifests/rbac.yaml',
  labels=['setup'],
)

local_resource(
  'registry',
  '''
  REGISTRY_IP=$(docker inspect ctlptl-registry --format '{{range .NetworkSettings.Networks}}{{.IPAddress}} {{end}}' | awk '{print $NF}')
  echo "Registry IP: $REGISTRY_IP"
  cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Service
metadata:
  name: ctlptl-registry
  namespace: unkey
spec:
  ports:
    - port: 5000
      targetPort: 5000
---
apiVersion: discovery.k8s.io/v1
kind: EndpointSlice
metadata:
  name: ctlptl-registry
  namespace: unkey
  labels:
    kubernetes.io/service-name: ctlptl-registry
addressType: IPv4
endpoints:
  - addresses:
      - "$REGISTRY_IP"
ports:
  - port: 5000
EOF
  ''',
  resource_deps=['namespace'],
  labels=['setup'],
)

local_resource(
  'cilium-policies',
  'kubectl apply -f k8s/manifests/cilium-policies.yaml',
  resource_deps=['namespace'],
  labels=['setup'],
)

# ─── TopoLVM (real LVM-backed PVCs for dev) ────────────────────────────────
#
# Customer pods get ephemeral PVCs via the StorageClass krane reads from
# config (`topolvm-ssd`). TopoLVM dynamically carves an LV per PVC out of
# `topolvm-vg`, formats it ext4, and mounts it in the customer pod — same
# semantics as ebs-csi-gp3 in prod, just backed by a loopback file inside
# the minikube node instead of an EBS volume.
#
# Three steps that have to run in order on every `tilt up`:
#   1. setup-vg.sh: create/reattach the loopback device + activate the VG
#      (idempotent, also handles `minikube stop`/`start` recovery).
#   2. helm install topolvm with the cert-manager-free / no-webhook config.
#   3. apply our StorageClass (provisioner: topolvm.io, fsType: ext4).
#
# The kubernetes-sigs csi-hostpath-driver addon is replaced — TopoLVM gives
# us per-volume filesystems so heimdall's statfs reports accurate per-pod
# usage and `df` inside the customer pod shows the allocated size, not the
# host disk.
local_resource(
  'topolvm-disable-old-csi',
  'minikube addons disable csi-hostpath-driver 2>&1 | tail -1 || true',
  labels=['storage'],
)

local_resource(
  'topolvm-vg',
  # Copy the script onto the node first and then run it with no stdin.
  # `minikube ssh -- bash < file` would work, but `minikube ssh` always
  # allocates a PTY and the wrapping SSH session keeps the terminal open
  # after the script exits, hanging Tilt. Copy + exec avoids the PTY trap.
  'minikube cp k8s/topolvm/setup-vg.sh /tmp/topolvm-setup-vg.sh && ' +
  'minikube ssh -- sudo bash /tmp/topolvm-setup-vg.sh ' + TOPOLVM_BACKING_SIZE,
  deps=['k8s/topolvm/setup-vg.sh'],
  resource_deps=['topolvm-disable-old-csi'],
  labels=['storage'],
)

helm_remote(
  'topolvm',
  repo_name='topolvm',
  repo_url='https://topolvm.github.io/topolvm',
  version='15.5.4',
  namespace='topolvm-system',
  create_namespace=True,
  values=['k8s/topolvm/values.yaml'],
)
# Force ordering so the helm install can't run before the VG exists.
# topolvm-lvmd-0 is the lvmd sidecar DaemonSet (one device class = one
# numbered DaemonSet); topolvm-node is the CSI node plugin DaemonSet.
k8s_resource(
  workload='topolvm-controller',
  resource_deps=['topolvm-vg'],
  labels=['storage'],
)
k8s_resource(
  workload='topolvm-node',
  resource_deps=['topolvm-vg'],
  labels=['storage'],
)
k8s_resource(
  workload='topolvm-lvmd-0',
  resource_deps=['topolvm-vg'],
  labels=['storage'],
)

local_resource(
  'topolvm-storageclass',
  'kubectl apply -f k8s/topolvm/storageclass.yaml',
  deps=['k8s/topolvm/storageclass.yaml'],
  resource_deps=['topolvm-controller', 'topolvm-node', 'topolvm-lvmd-0'],
  labels=['storage'],
)

local_resource(
  'hubble',
  'kubectl -n kube-system patch configmap cilium-config --type merge -p \'{"data":{"enable-hubble":"true","hubble-listen-address":":4244"}}\' && kubectl -n kube-system rollout restart daemonset cilium && kubectl apply -f k8s/manifests/hubble.yaml && kubectl -n kube-system rollout status daemonset cilium --timeout=120s',
  resource_deps=['cilium-policies'],
  labels=['observability'],
)

local_resource(
  'hubble-ui',
  serve_cmd='while true; do kubectl wait --for=condition=ready pod -l k8s-app=hubble-ui -n kube-system --timeout=120s && kubectl port-forward -n kube-system svc/hubble-ui 12000:80; echo "port-forward exited, retrying in 5s..."; sleep 5; done',
  resource_deps=['hubble'],
  labels=['observability'],
  links=['http://localhost:12000'],
)

local_resource(
    'depot-credentials',
    'if [ -f ./.env.depot ]; then kubectl -n unkey create secret generic depot-credentials --from-env-file=./.env.depot -o yaml --dry-run=client | kubectl apply -f -; else echo "Skipping depot-credentials (no .env.depot file)"; fi',
    resource_deps=['namespace'],
    deps=['./.env.depot'],
    labels=['setup'],
    allow_parallel=True,
)

local_resource(
    'github-credentials',
    '''if [ -f ./.env.github ] && [ -f ./.github-private-key.pem ]; then set -a && source ./.env.github && set +a && kubectl -n unkey create secret generic github-credentials \
      --from-literal=UNKEY_GITHUB_APP_ID="$UNKEY_GITHUB_APP_ID" \
      --from-literal=UNKEY_GITHUB_APP_WEBHOOK_SECRET="$UNKEY_GITHUB_APP_WEBHOOK_SECRET" \
      --from-literal=NEXT_PUBLIC_GITHUB_APP_NAME="$NEXT_PUBLIC_GITHUB_APP_NAME" \
      --from-literal=UNKEY_ALLOW_UNAUTHENTICATED_DEPLOYMENTS="$UNKEY_ALLOW_UNAUTHENTICATED_DEPLOYMENTS" \
      --from-file=UNKEY_GITHUB_PRIVATE_KEY_PEM=./.github-private-key.pem \
      -o yaml --dry-run=client | kubectl apply -f -; else echo "Skipping github-credentials (missing .env.github or .github-private-key.pem)"; fi''',
    resource_deps=['namespace'],
    deps=['./.env.github', './.github-private-key.pem'],
    labels=['setup'],
    allow_parallel=True,
)

local_resource(
    'domain-connect-credentials',
    '''if [ -f ./.domain-connect-private-key.pem ]; then kubectl -n unkey create secret generic domain-connect-credentials \
      --from-file=UNKEY_DOMAIN_CONNECT_PRIVATE_KEY=./.domain-connect-private-key.pem \
      -o yaml --dry-run=client | kubectl apply -f -; else echo "Skipping domain-connect-credentials (no .domain-connect-private-key.pem file)"; fi''',
    resource_deps=['namespace'],
    deps=['./.domain-connect-private-key.pem'],
    labels=['setup'],
    allow_parallel=True,
)

local_resource(
    'webhooks-config',
    'if [ -f ./.env.webhooks ]; then kubectl -n unkey create configmap ctrl-worker-webhooks --from-env-file=./.env.webhooks -o yaml --dry-run=client | kubectl apply -f -; else kubectl -n unkey delete configmap ctrl-worker-webhooks --ignore-not-found; fi',
    resource_deps=['namespace'],
    deps=['./.env.webhooks'],
    labels=['setup'],
    allow_parallel=True,
)

# Frontline TLS certificates - generates certs with mkcert if they don't exist
local_resource(
    'frontline-certs',
    'if [ ! -f ./certs/unkey.local.crt ]; then echo "Generating TLS certificates..." && command -v mkcert >/dev/null || { echo "ERROR: mkcert not found. Install with: brew install mkcert"; exit 1; } && mkcert -install && mkdir -p ./certs && mkcert -cert-file ./certs/unkey.local.crt -key-file ./certs/unkey.local.key "*.unkey.local" "unkey.local" "localhost" && echo "*.crt" > ./certs/.gitignore && echo "*.key" >> ./certs/.gitignore; fi && kubectl -n frontline create configmap frontline-certs --from-file=./certs/unkey.local.crt --from-file=./certs/unkey.local.key -o yaml --dry-run=client | kubectl apply -f -',
    resource_deps=['namespace'],
    labels=['setup'],
)

