# Clerk

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up

# Database

DATABASE_HOST="aws.connect.psdb.cloud"
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Unkey

UNKEY_WORKSPACE_ID=
UNKEY_API_ID=
UNKEY_API_URL=http://localhost:7070
UNKEY_JWT_SECRET=local-dev-jwt-secret-with-at-least-32-bytes

# Control Plane
CTRL_URL=http://127.0.0.1:7091
CTRL_API_KEY="your-local-dev-key"

# Vault
VAULT_URL=http://localhost:8060
VAULT_TOKEN=vault-test-token-123

# ClickHouse
CLICKHOUSE_URL=

# GitHub App (required for GitHub-triggered deployments)
# Run `go run . dev github setup` to generate these automatically
NEXT_PUBLIC_GITHUB_APP_NAME=
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe billing (required for the dashboard subscription flow).
# All four must be set or the dashboard treats Stripe as unconfigured.
# The product IDs below are the Deploy catalog products from the shared sandbox
# and are safe to commit (test mode). You only add two values:
#   STRIPE_SECRET_KEY     - a test-mode key (sk_test_...) from the shared sandbox
#   STRIPE_WEBHOOK_SECRET - from `stripe listen --forward-to http://localhost:3000/api/webhooks/stripe`
STRIPE_SECRET_KEY=
STRIPE_PRODUCT_IDS_PRO=prod_UfOFuZWPmvHX6g,prod_UfOFUUKrnrfAWK,prod_UfOFCoweeWpjbF,prod_UfOFDBB8uBAi7E,prod_UfOFdMJ2UugBEN,prod_UfOFDRJSJ9ywG9,prod_UfOFVIcciw5fLN
STRIPE_PRODUCT_IDS_ENTERPRISE=prod_UfOFaRxkNs1DJu
STRIPE_WEBHOOK_SECRET=

# Unkey Deploy billing price ids. Plan-fee price per tier (the canonical
# "has Deploy" item) plus the shared metered usage prices. Leave blank locally
# unless exercising the Deploy subscribe / change / cancel flows.
STRIPE_LOOKUP_DEPLOY_STARTER=
STRIPE_LOOKUP_DEPLOY_PRO=
STRIPE_LOOKUP_DEPLOY_BUSINESS=
STRIPE_LOOKUP_DEPLOY_METER_CPU=
STRIPE_LOOKUP_DEPLOY_METER_MEMORY=
STRIPE_LOOKUP_DEPLOY_METER_EGRESS=
STRIPE_LOOKUP_DEPLOY_METER_DISK=

# Dev only: create Stripe customers under a test clock so billing can be
# time-traveled. Advance clocks and fetch invoice PDFs with
# `unkey dev stripe` (mise run unkey -- dev stripe clock status).
STRIPE_DEV_TEST_CLOCK=

# Feature flags (local)
# Comma-separated list of flag keys to force "on" locally without configuring
# Vercel Flags. Handy for exercising flag-gated UI in dev, e.g.
# FLAGS_LOCAL_OVERRIDES="deploy-billing,hello-world".
FLAGS_LOCAL_OVERRIDES=

# Optional
TRIGGER_API_KEY=
NEXT_PUBLIC_TRIGGER_PUBLIC_KEY=
