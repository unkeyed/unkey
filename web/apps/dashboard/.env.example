# Clerk

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up

# Database

DATABASE_HOST="aws.connect.psdb.cloud"
DATABASE_USERNAME=
DATABASE_PASSWORD=

# Unkey

UNKEY_WORKSPACE_ID=
UNKEY_API_ID=
UNKEY_API_URL=http://localhost:7070
UNKEY_JWT_SECRET=local-dev-jwt-secret-with-at-least-32-bytes

# Control Plane
CTRL_URL=http://127.0.0.1:7091
CTRL_API_KEY="your-local-dev-key"

# Vault
VAULT_URL=http://localhost:8060
VAULT_TOKEN=vault-test-token-123

# ClickHouse
CLICKHOUSE_URL=

# GitHub App (required for GitHub-triggered deployments)
# Run `go run . dev github setup` to generate these automatically
NEXT_PUBLIC_GITHUB_APP_NAME=
GITHUB_APP_ID=

# Optional
TRIGGER_API_KEY=
NEXT_PUBLIC_TRIGGER_PUBLIC_KEY=
