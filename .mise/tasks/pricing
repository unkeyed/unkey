#!/usr/bin/env bash
#MISE description="Run the Stripe pricing catalog tool (usage: mise run pricing plan --env production)"
set -euo pipefail

cd "$MISE_PROJECT_ROOT/tools/pricing"

# Load local, untracked config (AWS profiles per environment, optional overrides).
# Copy .env.example to .env and fill it in; see that file for details.
set -a
[ -f .env ] && . ./.env
set +a

go run ./cmd/pricing "$@"
