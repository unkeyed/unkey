#!/usr/bin/env bash
#MISE description="Run the GitHub->Slack PR channel bot server"
set -euo pipefail

cd "$MISE_PROJECT_ROOT/tools/pr-channels"

# Load local, untracked config (tokens, DATABASE_URL).
