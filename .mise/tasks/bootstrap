#!/usr/bin/env bash
#MISE description="Bootstrap the repo"
set -euo pipefail

echo "Installing pinned toolchain..."
mise install

readonly ENV_FILE_DASHBOARD="web/apps/dashboard/.env"
readonly ENV_EXAMPLE_DASHBOARD="web/apps/dashboard/dev/.env.example"

# This file contains local secrets and machine-specific config. If it already
# exists, ask before replacing it so bootstrap never silently discards edits.
if [ -e "$ENV_FILE_DASHBOARD" ]; then
  echo "Bootstrap needs to recreate this file:" >&2
  echo "- $ENV_FILE_DASHBOARD" >&2

  read -r -p "Delete and recreate it? [y/N] " delete_env_files

  if [[ "$delete_env_files" != "y" && "$delete_env_files" != "Y" ]]; then
    echo "Bootstrap cancelled. Existing env files were left unchanged." >&2
    exit 1
  fi

  rm -f "$ENV_FILE_DASHBOARD"
fi

echo "Creating $ENV_FILE_DASHBOARD from $ENV_EXAMPLE_DASHBOARD..."
cp "$ENV_EXAMPLE_DASHBOARD" "$ENV_FILE_DASHBOARD"

# Add a github app and configure it.
echo "Configuring the local GitHub app..."
go run . dev github setup

echo "Bootstrap complete."
