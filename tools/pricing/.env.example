# Only needed for canary/production, which read the Stripe key from AWS Secrets
# Manager. Copy to .env (gitignored), fill in your AWS profiles, and `mise run
# pricing` loads it automatically.
#
# For sandbox/local, skip this file entirely and export STRIPE_SECRET_KEY instead.

AWS_PROFILE_SANDBOX=
AWS_PROFILE_CANARY=
AWS_PROFILE_PRODUCTION=

# Optional overrides (defaults shown):
# AWS_SSO_SESSION=unkey   # `aws sso login --sso-session <this>`
# AWS_REGION=us-east-1
# STRIPE_SECRET_ID=unkey/stripe
