# Copy to .env and fill in. The `mise run pr-channels` task loads this file.

# PlanetScale Postgres connection string (pgx format).
DATABASE_URL="postgres://user:pass@host/db?sslmode=verify-full"

# GitHub App webhook secret (Settings -> your App -> Webhook secret).
GITHUB_WEBHOOK_SECRET="..."

# Slack bot user OAuth token. Scopes: channels:manage, chat:write,
# reactions:write, users:read, users:read.email.
SLACK_BOT_TOKEN="xoxb-..."

# Optional. Comma-separated repo names to manage. Empty or "*" = whole org.
# REPO_ALLOWLIST="unkey"

# Optional. Overview feed channel ID (e.g. C0123456789). When set,
# opened (ready-for-review) and merged PRs are posted here. Per-PR review
# channels are created separately, only when a reviewer is requested. Leave
# empty to disable the feed.
# OVERVIEW_CHANNEL_ID="C0123456789"

# Optional overrides.
# PORT=8080
# ARCHIVE_DELAY=1m
# REMINDER_IDLE=18h
# REMINDER_INTERVAL=15m
